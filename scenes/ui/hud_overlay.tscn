[gd_scene load_steps=5 format=3 uid="uid://b00ye2t2s8s73"]

[ext_resource type="Script" path="res://scenes/ui/hud_overlay.gd" id="1_h"]

[sub_resource type="Shader" id="Shader_crt"]
code = "shader_type canvas_item;

uniform float scanline_count = 350.0;
uniform float crt_curve = 0.015;
uniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_nearest;

void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 uv_curved = uv - 0.5;
	uv_curved.x *= 1.0 + pow(abs(uv_curved.y) * crt_curve, 2.0);
	uv_curved.y *= 1.0 + pow(abs(uv_curved.x) * crt_curve, 2.0);
	uv = uv_curved + 0.5;
	
	if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) {
		COLOR = vec4(0.0, 0.0, 0.0, 1.0);
	} else {
		vec4 color = texture(screen_texture, uv);
		float scanline = sin(uv.y * scanline_count * 3.14159 * 2.0) * 0.035;
		color.rgb -= vec3(scanline);
		float vignette = uv.x * uv.y * (1.0 - uv.x) * (1.0 - uv.y);
		vignette = clamp(pow(16.0 * vignette, 0.2), 0.0, 1.0);
		color.rgb *= vignette;
		COLOR = color;
	}
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_crt"]
shader = SubResource("Shader_crt")

